<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="expo.modules.notificationlistener" >

    <uses-sdk android:minSdkVersion="24" />

    <!--
    BIND_NOTIFICATION_LISTENER_SERVICE is a signature-level permission.
    It cannot be granted via requestPermissions(); the user must enable
    this app manually in Settings → Apps → Notification Access.
    -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE" />

    <application>
        <service
            android:name="expo.modules.notificationlistener.FinwardNotificationListenerService"
            android:exported="true"
            android:label="FinWard Notification Listener"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE" >
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
    </application>

</manifest>